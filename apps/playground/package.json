{
  "name": "@motes/playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ../../registry/build.mjs && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:glsl": "vitest run --config vitest.glsl.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "registry": "node ../../registry/build.mjs"
  },
  "dependencies": {
    "@lucasmarkes/motes": "workspace:*",
    "@lucasmarkes/motes-react": "workspace:*",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
