{
  "name": "@lucasmarkes/motes-react",
  "version": "0.2.0",
  "description": "React wrapper for motes \u2014 procedural, pointer-reactive ASCII fields",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@lucasmarkes/motes": "workspace:^"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasmarkes/motes.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/lucasmarkes/motes/issues"
  },
  "homepage": "https://motes.lucasmarkes.com"
}
