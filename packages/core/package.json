{
  "name": "motes",
  "version": "0.1.0",
  "description": "Procedural, pointer-reactive ASCII fields for the web",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "ascii",
    "webgl",
    "webgl2",
    "background",
    "generative",
    "procedural",
    "pointer",
    "interactive"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
